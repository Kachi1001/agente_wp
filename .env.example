# Porta em que o agente irá rodar
PORT=3005

# (Opcional) URL de webhook global de fallback.
# Na maioria dos casos com múltiplas aplicações, deixe em branco
# e use o parâmetro webhookUrl ao registrar cada sessão individualmente.
WEBHOOK_URL=

# Chave de segurança enviada no header Authorization de cada webhook para o Next.js
# Use uma string longa e aleatória. Ex: openssl rand -hex 32
WEBHOOK_SECRET=troque-por-uma-chave-secreta-forte

# OpenRouter API Key para o script de AI Reviewer
OPENROUTER_API_KEY=

# ── Integração SSO (painel /admin) ──────────────────────────────────────────
# URL base da Central SSO da Tecnika.
CENTRAL_AUTH_URL=http://10.0.0.139:4000
# ID NUMÉRICO desta app (apps.id na Central). PRECISA ser o número, não o nome —
# o adminAuth compara contra allowedApps[].id; com string dá 403 após o login.
APP_ID=28

# URL da Central Tecnika — usada pelo GET /api/logs para validar o JWT do admin.
# Default: http://10.0.0.139:4000 (cai em CENTRAL_AUTH_URL se não definida).
CENTRAL_URL=http://10.0.0.139:4000

