# Porta em que o agente irá rodar
PORT=3005

# (Opcional) URL de webhook global de fallback.
# Na maioria dos casos com múltiplas aplicações, deixe em branco
# e use o parâmetro webhookUrl ao registrar cada sessão individualmente.
WEBHOOK_URL=

# Chave de segurança enviada no header Authorization de cada webhook para o Next.js
# Use uma string longa e aleatória. Ex: openssl rand -hex 32
WEBHOOK_SECRET=troque-por-uma-chave-secreta-forte
